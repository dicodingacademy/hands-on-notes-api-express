# Port tempat server Express berjalan
PORT=5000

# Alamat koneksi PostgreSQL (format: postgres://user:password@host:port/nama_db)
DATABASE_URL=postgres://notes_user:notes_password@localhost:5432/notes_db

# Kunci rahasia untuk menandatangani JWT — WAJIB diganti di produksi
JWT_SECRET=ganti-dengan-kunci-rahasia-yang-panjang

# Daftar origin frontend yang diizinkan mengakses API (pisahkan dengan koma)
CORS_ORIGIN=http://localhost:5173

# URL layanan AI eksternal untuk endpoint POST /api/classify
AI_SERVICE_URL=https://url-ai
