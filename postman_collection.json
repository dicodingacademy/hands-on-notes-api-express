{
  "info": {
    "name": "Notes API - Express",
    "description": "Koleksi request untuk menguji Notes API (Express). Urutan pemakaian: Health Check → Register → Login (token otomatis tersimpan ke variabel koleksi) → request Catatan. Ubah variabel `baseUrl` untuk menguji server yang sudah di-deploy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "description": "Alamat server backend — ganti dengan URL server kalian setelah deployment"
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "Terisi otomatis setelah request Login berhasil"
    },
    {
      "key": "noteId",
      "value": "1",
      "description": "Terisi otomatis setelah request Buat Catatan berhasil"
    },
    {
      "key": "username",
      "value": "budi",
      "description": "Terisi otomatis dengan username unik saat request Register dijalankan"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health",
        "description": "Endpoint publik untuk memverifikasi server hidup. Respons: { \"status\": \"ok\" }"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"rahasia123\"\n}"
            },
            "description": "Mendaftarkan user baru. Username dibuat unik otomatis (lihat pre-request script) agar koleksi bisa dijalankan berulang. Validasi: username unik 3-50 karakter, password minimal 6 karakter. Respons sukses: 201 + { \"data\": { \"id\", \"username\" } }"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Buat username unik setiap dijalankan supaya tidak bentrok dengan user yang sudah ada",
                  "pm.collectionVariables.set('username', 'budi' + Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Respons berisi data.id dan data.username', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('id');",
                  "  pm.expect(json.data).to.have.property('username');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"rahasia123\"\n}"
            },
            "description": "Masuk dengan username + password (memakai username dari request Register). Access token dari respons otomatis disimpan ke variabel koleksi `accessToken` sehingga request Catatan langsung bisa dipakai."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Respons berisi accessToken', () => {",
                  "  pm.expect(json.data).to.have.property('accessToken');",
                  "});",
                  "// Simpan token agar otomatis terpakai oleh request Catatan",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catatan",
      "description": "Semua request di folder ini butuh header Authorization: Bearer <accessToken> — terisi otomatis dari variabel koleksi setelah Login.",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Buat Catatan",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/notes",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Catatan pertama\",\n  \"body\": \"Isi catatan bebas\"\n}"
            },
            "description": "Membuat catatan baru. Validasi: title wajib non-kosong maksimal 100 karakter. Respons sukses: 201 + { \"data\": Note }"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "// Simpan id catatan agar request Detail/Hapus langsung bisa dipakai",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('noteId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Daftar Catatan",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notes",
            "description": "Daftar catatan milik user yang sedang login. Respons: { \"data\": [Note] }"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('data berupa array', () => {",
                  "  pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Detail Catatan",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notes/{{noteId}}",
            "description": "Detail satu catatan milik user. Catatan milik user lain menghasilkan 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Hapus Catatan",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/notes/{{noteId}}",
            "description": "Menghapus catatan milik user. Respons sukses: 200 + { \"data\": { \"id\" } }"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Contoh Kasus Gagal",
      "item": [
        {
          "name": "Register - username terlalu pendek (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ab\",\n  \"password\": \"rahasia123\"\n}"
            },
            "description": "Validasi gagal menghasilkan 400 + { \"error\": \"<pesan>\" }"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Respons berisi pesan error', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Daftar Catatan - tanpa token (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notes",
            "description": "Mengakses endpoint terproteksi tanpa header Authorization menghasilkan 401.",
            "auth": { "type": "noauth" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
